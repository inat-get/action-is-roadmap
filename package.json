{
  "name": "action-is-roadmap",
  "description": "Generates Mermaid flowchart roadmap from GitHub Milestones, Issues and Dependencies",
  "version": "0.1.0",
  "author": "Ivan Shikhalev",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "npm run format:write && npm run package",
    "package": "rimraf ./dist && rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "bundle": "npm run package",
    "format:write": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest",
    "ci-test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest --ci --coverage",
    "all": "npm run format:write && npm run lint && npm run test && npm run package"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^9.0.0",
    "@octokit/graphql": "^9.0.3",
    "@octokit/rest": "^21.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.4",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.2.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.0.1",
    "rollup": "^4.60.1",
    "ts-jest": "^29.4.9",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  },
  "overrides": {
    "undici": "^6.24.0"
  }
}
